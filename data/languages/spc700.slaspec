:MOV1 "C",!$bitaddr "."^bitnum is op=0xaa; bitaddr & bitnum { local addr:2 = bitaddr; local value:1 = *:1 addr; local mask:1 = 1 << bitnum; CF = ((value & mask) != 0); pack_psw(); }
