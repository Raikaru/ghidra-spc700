# Sony SPC700 processor module scaffold with a first useful instruction subset.
# The SPC700 has a 16-bit program counter and an 8-bit stack pointer into page $01.

define endian=little;
define alignment=1;

define space ram      type=ram_space      size=2 default;
define space register type=register_space size=1;

define register offset=0x00 size=2 [ PC ];
define register offset=0x10 size=1 [ A X Y SP PSW ];
define register offset=0x20 size=1 [ NF VF PF BF HF IF ZF CF ];
define register offset=0x30 size=4 contextreg;
define context contextreg
  ctx_P=(0,0)
;

define token opbyte (8)
  op = (0,7)
;

define pcodeop spc_brk;
define pcodeop spc_sleep;
define pcodeop spc_stop;

define token data8 (8)
  imm8 = (0,7)
  rel8 = (0,7) signed
;

define token data16 (16)
  imm16 = (0,15)
  bitaddr = (0,12)
  bitnum = (13,15)
  src8 = (0,7)
  dst8 = (8,15)
;

macro pack_psw() {
  PSW = (NF << 7) | (VF << 6) | (PF << 5) | (BF << 4) | (HF << 3) | (IF << 2) | (ZF << 1) | CF;
}

macro unpack_psw() {
  NF = (PSW >> 7) & 1;
  VF = (PSW >> 6) & 1;
  PF = (PSW >> 5) & 1;
  BF = (PSW >> 4) & 1;
  HF = (PSW >> 3) & 1;
  IF = (PSW >> 2) & 1;
  ZF = (PSW >> 1) & 1;
  CF = PSW & 1;
}

macro flags_nz8(v) {
  local value:1 = v;
  ZF = (value == 0);
  NF = (value s< 0);
  pack_psw();
}

macro flags_adc8(lhs, rhs, carry, result) {
  local wide:2 = zext(lhs) + zext(rhs) + zext(carry);
  CF = (wide > 0xff);
  HF = (((lhs ^ rhs ^ result) & 0x10) != 0);
  VF = (((lhs ^ result) & (rhs ^ result) & 0x80) != 0);
  flags_nz8(result);
}

macro flags_sbc8(lhs, rhs, borrow, result) {
  local subtrahend:2 = zext(rhs) + zext(borrow);
  CF = (zext(lhs) >= subtrahend);
  HF = (((lhs ^ rhs ^ result) & 0x10) != 0);
  VF = (((lhs ^ rhs) & (lhs ^ result) & 0x80) != 0);
  flags_nz8(result);
}

macro adc_a(value) {
  local olda:1 = A;
  local carry:1 = CF;
  A = A + value + carry;
  flags_adc8(olda, value, carry, A);
}

macro sbc_a(value) {
  local olda:1 = A;
  local borrow:1 = (CF == 0);
  A = A - value - borrow;
  flags_sbc8(olda, value, borrow, A);
}

macro cmp8(lhs, rhs) {
  local result:1 = lhs - rhs;
  CF = (lhs >= rhs);
  flags_nz8(result);
}

macro flags_nzc8(v, carry) {
  CF = carry;
  flags_nz8(v);
}

macro flags_nzvch16(lhs, rhs, result) {
  local wide:4 = zext(lhs) + zext(rhs);
  CF = (wide > 0xffff);
  HF = (((lhs ^ rhs ^ result) & 0x1000) != 0);
  VF = (((lhs ^ result) & (rhs ^ result) & 0x8000) != 0);
  ZF = (result == 0);
  NF = (result s< 0);
  pack_psw();
}

macro cmp16(lhs, rhs) {
  local result:2 = lhs - rhs;
  CF = (lhs >= rhs);
  ZF = (result == 0);
  NF = (result s< 0);
  pack_psw();
}

macro ya_nz16(v) {
  ZF = (v == 0);
  NF = (v s< 0);
  pack_psw();
}

macro stack_addr(out) {
  out = 0x0100 | zext(SP);
}

macro push8(v) {
  local addr:2;
  stack_addr(addr);
  *:1 addr = v;
  SP = SP - 1;
}

macro pop8(out) {
  SP = SP + 1;
  local addr:2;
  stack_addr(addr);
  out = *:1 addr;
}

macro dp_reg_addr(out, offset) {
  out = (zext(PF) << 8) | zext(offset);
}

macro dp_high_addr(out, addr) {
  out = (addr & 0xff00) | ((addr + 1) & 0x00ff);
}

macro read_dp16(out, addr) {
  local hiAddr:2;
  dp_high_addr(hiAddr, addr);
  local lo:1 = *:1 addr;
  local hi:1 = *:1 hiAddr;
  out = zext(lo) | (zext(hi) << 8);
}

macro write_dp16(addr, value) {
  local hiAddr:2;
  dp_high_addr(hiAddr, addr);
  *:1 addr = value:1;
  *:1 hiAddr = value(1);
}

RelTarget: $target is rel8 [ target = (inst_next + rel8) & 0xffff; ] { export *:2 target; }
PCallTarget: $target is imm8 [ target = 0xff00 + imm8; ] { export *:2 target; }
Abs: !$imm16 is imm16 { local addr:2 = imm16; export addr; }
AbsX: !$imm16 "+X" is imm16 { local addr:2 = imm16 + zext(X); export addr; }
AbsY: !$imm16 "+Y" is imm16 { local addr:2 = imm16 + zext(Y); export addr; }
Dp: <$imm8 is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export addr; }
Dp: <$imm8 is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export addr; }
DpX: <$imm8 "+X" is ctx_P=0 & imm8 { local low:1 = imm8 + X; local addr:2 = zext(low); export addr; }
DpX: <$imm8 "+X" is ctx_P=1 & imm8 { local low:1 = imm8 + X; local addr:2 = 0x0100 + zext(low); export addr; }
DpY: <$imm8 "+Y" is ctx_P=0 & imm8 { local low:1 = imm8 + Y; local addr:2 = zext(low); export addr; }
DpY: <$imm8 "+Y" is ctx_P=1 & imm8 { local low:1 = imm8 + Y; local addr:2 = 0x0100 + zext(low); export addr; }
DpXInd: [$imm8 "+X"] is ctx_P=0 & imm8 { local ptrLo:1 = imm8 + X; local ptrHi:1 = ptrLo + 1; local loAddr:2 = zext(ptrLo); local hiAddr:2 = zext(ptrHi); local lo:1 = *:1 loAddr; local hi:1 = *:1 hiAddr; local addr:2 = zext(lo) | (zext(hi) << 8); export addr; }
DpXInd: [$imm8 "+X"] is ctx_P=1 & imm8 { local ptrLo:1 = imm8 + X; local ptrHi:1 = ptrLo + 1; local loAddr:2 = 0x0100 + zext(ptrLo); local hiAddr:2 = 0x0100 + zext(ptrHi); local lo:1 = *:1 loAddr; local hi:1 = *:1 hiAddr; local addr:2 = zext(lo) | (zext(hi) << 8); export addr; }
DpIndY: [$imm8] "+Y" is ctx_P=0 & imm8 { local ptrLo:1 = imm8; local ptrHi:1 = ptrLo + 1; local loAddr:2 = zext(ptrLo); local hiAddr:2 = zext(ptrHi); local lo:1 = *:1 loAddr; local hi:1 = *:1 hiAddr; local addr:2 = (zext(lo) | (zext(hi) << 8)) + zext(Y); export addr; }
DpIndY: [$imm8] "+Y" is ctx_P=1 & imm8 { local ptrLo:1 = imm8; local ptrHi:1 = ptrLo + 1; local loAddr:2 = 0x0100 + zext(ptrLo); local hiAddr:2 = 0x0100 + zext(ptrHi); local lo:1 = *:1 loAddr; local hi:1 = *:1 hiAddr; local addr:2 = (zext(lo) | (zext(hi) << 8)) + zext(Y); export addr; }
Imm8: #$imm8 is imm8 { export *[const]:1 imm8; }
DpSrc: <$src8 is ctx_P=0 & src8 { local addr:2 = 0; addr = src8; export addr; }
DpSrc: <$src8 is ctx_P=1 & src8 { local off:2 = 0; off = src8; local addr:2 = 0x0100 + off; export addr; }
DpDst: <$dst8 is ctx_P=0 & dst8 { local addr:2 = 0; addr = dst8; export addr; }
DpDst: <$dst8 is ctx_P=1 & dst8 { local off:2 = 0; off = dst8; local addr:2 = 0x0100 + off; export addr; }
ImmSrc: #$src8 is src8 { export *[const]:1 src8; }
DpBit0: <$imm8 ".0" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit0: <$imm8 ".0" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }
DpBit1: <$imm8 ".1" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit1: <$imm8 ".1" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }
DpBit2: <$imm8 ".2" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit2: <$imm8 ".2" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }
DpBit3: <$imm8 ".3" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit3: <$imm8 ".3" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }
DpBit4: <$imm8 ".4" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit4: <$imm8 ".4" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }
DpBit5: <$imm8 ".5" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit5: <$imm8 ".5" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }
DpBit6: <$imm8 ".6" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit6: <$imm8 ".6" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }
DpBit7: <$imm8 ".7" is ctx_P=0 & imm8 { local addr:2 = 0; addr = imm8; export *:1 addr; }
DpBit7: <$imm8 ".7" is ctx_P=1 & imm8 { local off:2 = 0; off = imm8; local addr:2 = 0x0100 + off; export *:1 addr; }

:NOP is op=0x00 { }

:BRA RelTarget is op=0x2f; RelTarget { goto RelTarget; }
:BEQ RelTarget is op=0xf0; RelTarget { if (ZF != 0) goto RelTarget; }
:BNE RelTarget is op=0xd0; RelTarget { if (ZF == 0) goto RelTarget; }
:BMI RelTarget is op=0x30; RelTarget { if (NF != 0) goto RelTarget; }
:BPL RelTarget is op=0x10; RelTarget { if (NF == 0) goto RelTarget; }
:BCS RelTarget is op=0xb0; RelTarget { if (CF != 0) goto RelTarget; }
:BCC RelTarget is op=0x90; RelTarget { if (CF == 0) goto RelTarget; }
:BVS RelTarget is op=0x70; RelTarget { if (VF != 0) goto RelTarget; }
:BVC RelTarget is op=0x50; RelTarget { if (VF == 0) goto RelTarget; }

:BBS DpBit0,RelTarget is op=0x03; DpBit0; RelTarget { if ((DpBit0 & 0x01) != 0) goto RelTarget; }
:BBC DpBit0,RelTarget is op=0x13; DpBit0; RelTarget { if ((DpBit0 & 0x01) == 0) goto RelTarget; }
:BBS DpBit1,RelTarget is op=0x23; DpBit1; RelTarget { if ((DpBit1 & 0x02) != 0) goto RelTarget; }
:BBC DpBit1,RelTarget is op=0x33; DpBit1; RelTarget { if ((DpBit1 & 0x02) == 0) goto RelTarget; }
:BBS DpBit2,RelTarget is op=0x43; DpBit2; RelTarget { if ((DpBit2 & 0x04) != 0) goto RelTarget; }
:BBC DpBit2,RelTarget is op=0x53; DpBit2; RelTarget { if ((DpBit2 & 0x04) == 0) goto RelTarget; }
:BBS DpBit3,RelTarget is op=0x63; DpBit3; RelTarget { if ((DpBit3 & 0x08) != 0) goto RelTarget; }
:BBC DpBit3,RelTarget is op=0x73; DpBit3; RelTarget { if ((DpBit3 & 0x08) == 0) goto RelTarget; }
:BBS DpBit4,RelTarget is op=0x83; DpBit4; RelTarget { if ((DpBit4 & 0x10) != 0) goto RelTarget; }
:BBC DpBit4,RelTarget is op=0x93; DpBit4; RelTarget { if ((DpBit4 & 0x10) == 0) goto RelTarget; }
:BBS DpBit5,RelTarget is op=0xa3; DpBit5; RelTarget { if ((DpBit5 & 0x20) != 0) goto RelTarget; }
:BBC DpBit5,RelTarget is op=0xb3; DpBit5; RelTarget { if ((DpBit5 & 0x20) == 0) goto RelTarget; }
:BBS DpBit6,RelTarget is op=0xc3; DpBit6; RelTarget { if ((DpBit6 & 0x40) != 0) goto RelTarget; }
:BBC DpBit6,RelTarget is op=0xd3; DpBit6; RelTarget { if ((DpBit6 & 0x40) == 0) goto RelTarget; }
:BBS DpBit7,RelTarget is op=0xe3; DpBit7; RelTarget { if ((DpBit7 & 0x80) != 0) goto RelTarget; }
:BBC DpBit7,RelTarget is op=0xf3; DpBit7; RelTarget { if ((DpBit7 & 0x80) == 0) goto RelTarget; }

:CBNE Dp,RelTarget is op=0x2e; Dp; RelTarget { if (A != *:1 Dp) goto RelTarget; }
:CBNE DpX,RelTarget is op=0xde; DpX; RelTarget { if (A != *:1 DpX) goto RelTarget; }
:DBNZ Dp,RelTarget is op=0x6e; Dp; RelTarget { *:1 Dp = *:1 Dp - 1; if (*:1 Dp != 0) goto RelTarget; }
:DBNZ "Y",RelTarget is op=0xfe; RelTarget { Y = Y - 1; if (Y != 0) goto RelTarget; }

:CALL Abs is op=0x3f; Abs { call Abs; }
:JMP Abs is op=0x5f; Abs { goto Abs; }
:JMP "[" !$imm16 "+X]" is op=0x1f; imm16 { local ptr:2 = imm16 + zext(X); goto [*:2 ptr]; }
:PCALL PCallTarget is op=0x4f; PCallTarget { call PCallTarget; }
:TCALL "0" is op=0x01 { local ptr:2 = 0xffde; call [*:2 ptr]; }
:TCALL "1" is op=0x11 { local ptr:2 = 0xffdc; call [*:2 ptr]; }
:TCALL "2" is op=0x21 { local ptr:2 = 0xffda; call [*:2 ptr]; }
:TCALL "3" is op=0x31 { local ptr:2 = 0xffd8; call [*:2 ptr]; }
:TCALL "4" is op=0x41 { local ptr:2 = 0xffd6; call [*:2 ptr]; }
:TCALL "5" is op=0x51 { local ptr:2 = 0xffd4; call [*:2 ptr]; }
:TCALL "6" is op=0x61 { local ptr:2 = 0xffd2; call [*:2 ptr]; }
:TCALL "7" is op=0x71 { local ptr:2 = 0xffd0; call [*:2 ptr]; }
:TCALL "8" is op=0x81 { local ptr:2 = 0xffce; call [*:2 ptr]; }
:TCALL "9" is op=0x91 { local ptr:2 = 0xffcc; call [*:2 ptr]; }
:TCALL "10" is op=0xa1 { local ptr:2 = 0xffca; call [*:2 ptr]; }
:TCALL "11" is op=0xb1 { local ptr:2 = 0xffc8; call [*:2 ptr]; }
:TCALL "12" is op=0xc1 { local ptr:2 = 0xffc6; call [*:2 ptr]; }
:TCALL "13" is op=0xd1 { local ptr:2 = 0xffc4; call [*:2 ptr]; }
:TCALL "14" is op=0xe1 { local ptr:2 = 0xffc2; call [*:2 ptr]; }
:TCALL "15" is op=0xf1 { local ptr:2 = 0xffc0; call [*:2 ptr]; }
:RET is op=0x6f { local retsp:1 = SP + 1; local addr:2 = 0x0100 | zext(retsp); return [*:2 addr]; }
:RETI is op=0x7f { pop8(PSW); unpack_psw(); local retsp:1 = SP + 1; local addr:2 = 0x0100 | zext(retsp); SP = SP + 2; return [*:2 addr]; }
:BRK is op=0x0f { BF = 1; IF = 0; pack_psw(); spc_brk(); }
:SLEEP is op=0xef { spc_sleep(); }
:STOP is op=0xff { spc_stop(); }

:MOV "A",Imm8 is op=0xe8; Imm8 { A = Imm8; flags_nz8(A); }
:MOV "X",Imm8 is op=0xcd; Imm8 { X = Imm8; flags_nz8(X); }
:MOV "Y",Imm8 is op=0x8d; Imm8 { Y = Imm8; flags_nz8(Y); }

:MOV "A","(X)" is op=0xe6 { local addr:2; dp_reg_addr(addr, X); A = *:1 addr; flags_nz8(A); }
:MOV "A","(X)+" is op=0xbf { local addr:2; dp_reg_addr(addr, X); A = *:1 addr; X = X + 1; flags_nz8(A); }
:MOV "A",Dp is op=0xe4; Dp { A = *:1 Dp; flags_nz8(A); }
:MOV "A",DpX is op=0xf4; DpX { A = *:1 DpX; flags_nz8(A); }
:MOV "A",Abs is op=0xe5; Abs { A = *:1 Abs; flags_nz8(A); }
:MOV "A",AbsX is op=0xf5; AbsX { A = *:1 AbsX; flags_nz8(A); }
:MOV "A",AbsY is op=0xf6; AbsY { A = *:1 AbsY; flags_nz8(A); }
:MOV "A",DpXInd is op=0xe7; DpXInd { A = *:1 DpXInd; flags_nz8(A); }
:MOV "A",DpIndY is op=0xf7; DpIndY { A = *:1 DpIndY; flags_nz8(A); }

:MOV "X",Dp is op=0xf8; Dp { X = *:1 Dp; flags_nz8(X); }
:MOV "X",DpY is op=0xf9; DpY { X = *:1 DpY; flags_nz8(X); }
:MOV "X",Abs is op=0xe9; Abs { X = *:1 Abs; flags_nz8(X); }
:MOV "Y",Dp is op=0xeb; Dp { Y = *:1 Dp; flags_nz8(Y); }
:MOV "Y",DpX is op=0xfb; DpX { Y = *:1 DpX; flags_nz8(Y); }
:MOV "Y",Abs is op=0xec; Abs { Y = *:1 Abs; flags_nz8(Y); }

:MOV "(X)","A" is op=0xc6 { local addr:2; dp_reg_addr(addr, X); *:1 addr = A; }
:MOV "(X)+","A" is op=0xaf { local addr:2; dp_reg_addr(addr, X); *:1 addr = A; X = X + 1; }
:MOV Dp,"A" is op=0xc4; Dp { *:1 Dp = A; }
:MOV DpX,"A" is op=0xd4; DpX { *:1 DpX = A; }
:MOV Abs,"A" is op=0xc5; Abs { *:1 Abs = A; }
:MOV AbsX,"A" is op=0xd5; AbsX { *:1 AbsX = A; }
:MOV AbsY,"A" is op=0xd6; AbsY { *:1 AbsY = A; }
:MOV DpXInd,"A" is op=0xc7; DpXInd { *:1 DpXInd = A; }
:MOV DpIndY,"A" is op=0xd7; DpIndY { *:1 DpIndY = A; }

:MOV Dp,"X" is op=0xd8; Dp { *:1 Dp = X; }
:MOV DpY,"X" is op=0xd9; DpY { *:1 DpY = X; }
:MOV Abs,"X" is op=0xc9; Abs { *:1 Abs = X; }
:MOV Dp,"Y" is op=0xcb; Dp { *:1 Dp = Y; }
:MOV DpX,"Y" is op=0xdb; DpX { *:1 DpX = Y; }
:MOV Abs,"Y" is op=0xcc; Abs { *:1 Abs = Y; }

:MOV DpDst,DpSrc is op=0xfa; DpSrc & DpDst { *:1 DpDst = *:1 DpSrc; }
:MOV DpDst,ImmSrc is op=0x8f; ImmSrc & DpDst { *:1 DpDst = ImmSrc; }

:MOV "A","X" is op=0x7d { A = X; flags_nz8(A); }
:MOV "A","Y" is op=0xdd { A = Y; flags_nz8(A); }
:MOV "X","A" is op=0x5d { X = A; flags_nz8(X); }
:MOV "Y","A" is op=0xfd { Y = A; flags_nz8(Y); }
:MOV "X","SP" is op=0x9d { X = SP; flags_nz8(X); }
:MOV "SP","X" is op=0xbd { SP = X; }


:ADC "A",Imm8 is op=0x88; Imm8 { adc_a(Imm8); }
:SBC "A",Imm8 is op=0xa8; Imm8 { sbc_a(Imm8); }
:AND "A",Imm8 is op=0x28; Imm8 { A = A & Imm8; flags_nz8(A); }
:EOR "A",Imm8 is op=0x48; Imm8 { A = A ^ Imm8; flags_nz8(A); }
:OR "A",Imm8 is op=0x08; Imm8 { A = A | Imm8; flags_nz8(A); }
:CMP "A",Imm8 is op=0x68; Imm8 { cmp8(A, Imm8); }

:ADC "A","(X)" is op=0x86 { local addr:2; dp_reg_addr(addr, X); adc_a(*:1 addr); }
:ADC "A",Dp is op=0x84; Dp { adc_a(*:1 Dp); }
:ADC "A",DpX is op=0x94; DpX { adc_a(*:1 DpX); }
:ADC "A",Abs is op=0x85; Abs { adc_a(*:1 Abs); }
:ADC "A",AbsX is op=0x95; AbsX { adc_a(*:1 AbsX); }
:ADC "A",AbsY is op=0x96; AbsY { adc_a(*:1 AbsY); }
:ADC "A",DpXInd is op=0x87; DpXInd { adc_a(*:1 DpXInd); }
:ADC "A",DpIndY is op=0x97; DpIndY { adc_a(*:1 DpIndY); }

:SBC "A","(X)" is op=0xa6 { local addr:2; dp_reg_addr(addr, X); sbc_a(*:1 addr); }
:SBC "A",Dp is op=0xa4; Dp { sbc_a(*:1 Dp); }
:SBC "A",DpX is op=0xb4; DpX { sbc_a(*:1 DpX); }
:SBC "A",Abs is op=0xa5; Abs { sbc_a(*:1 Abs); }
:SBC "A",AbsX is op=0xb5; AbsX { sbc_a(*:1 AbsX); }
:SBC "A",AbsY is op=0xb6; AbsY { sbc_a(*:1 AbsY); }
:SBC "A",DpXInd is op=0xa7; DpXInd { sbc_a(*:1 DpXInd); }
:SBC "A",DpIndY is op=0xb7; DpIndY { sbc_a(*:1 DpIndY); }

:AND "A","(X)" is op=0x26 { local addr:2; dp_reg_addr(addr, X); A = A & *:1 addr; flags_nz8(A); }
:AND "A",Dp is op=0x24; Dp { A = A & *:1 Dp; flags_nz8(A); }
:AND "A",DpX is op=0x34; DpX { A = A & *:1 DpX; flags_nz8(A); }
:AND "A",Abs is op=0x25; Abs { A = A & *:1 Abs; flags_nz8(A); }
:AND "A",AbsX is op=0x35; AbsX { A = A & *:1 AbsX; flags_nz8(A); }
:AND "A",AbsY is op=0x36; AbsY { A = A & *:1 AbsY; flags_nz8(A); }
:AND "A",DpXInd is op=0x27; DpXInd { A = A & *:1 DpXInd; flags_nz8(A); }
:AND "A",DpIndY is op=0x37; DpIndY { A = A & *:1 DpIndY; flags_nz8(A); }

:EOR "A","(X)" is op=0x46 { local addr:2; dp_reg_addr(addr, X); A = A ^ *:1 addr; flags_nz8(A); }
:EOR "A",Dp is op=0x44; Dp { A = A ^ *:1 Dp; flags_nz8(A); }
:EOR "A",DpX is op=0x54; DpX { A = A ^ *:1 DpX; flags_nz8(A); }
:EOR "A",Abs is op=0x45; Abs { A = A ^ *:1 Abs; flags_nz8(A); }
:EOR "A",AbsX is op=0x55; AbsX { A = A ^ *:1 AbsX; flags_nz8(A); }
:EOR "A",AbsY is op=0x56; AbsY { A = A ^ *:1 AbsY; flags_nz8(A); }
:EOR "A",DpXInd is op=0x47; DpXInd { A = A ^ *:1 DpXInd; flags_nz8(A); }
