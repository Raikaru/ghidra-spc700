:OR1 "C",!$bitaddr "."^bitnum is op=0x0a; bitaddr & bitnum { local addr:2 = bitaddr; local value:1 = *:1 addr; local mask:1 = 1 << bitnum; CF = (CF != 0) || ((value & mask) != 0); pack_psw(); }
